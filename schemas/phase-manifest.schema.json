{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainstorming.local/schemas/phase-manifest.schema.json",
  "title": "BrainStorming Phase Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "topic_slug",
    "phase",
    "agent",
    "status",
    "outputs",
    "key_finding",
    "quality_signal"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "topic_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "phase": {
      "type": "string",
      "enum": [
        "phase_1_researcher",
        "phase_1_investigator",
        "phase_1b_gap_fill",
        "phase_2_analyzer",
        "phase_3_writer",
        "phase_4_critic",
        "phase_5_security",
        "phase_6_tester",
        "phase_6_5_challenger",
        "phase_7_publisher"
      ]
    },
    "agent": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["COMPLETE", "PARTIAL", "FAILED", "SKIPPED"]
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "key_finding": {
      "type": "string",
      "minLength": 1
    },
    "quality_signal": {
      "type": "string",
      "minLength": 1
    },
    "source_count": {
      "type": "number",
      "minimum": 0
    },
    "confidence_counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "HIGH": { "type": "number", "minimum": 0 },
        "MEDIUM": { "type": "number", "minimum": 0 },
        "LOW": { "type": "number", "minimum": 0 },
        "UNVERIFIED": { "type": "number", "minimum": 0 }
      }
    },
    "must_survive_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "followup_needed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "token_count": {
      "type": "number",
      "minimum": 0
    },
    "weighted_total": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "verdict": {
      "type": "string"
    },
    "dimension_scores": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 10 }
    },
    "required_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "must_survive_missing": {
      "type": "array",
      "items": { "type": "string" }
    },
    "review_incorporation_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "phase": { "const": "phase_4_critic" } },
        "required": ["phase"]
      },
      "then": {
        "required": ["weighted_total", "verdict"]
      }
    }
  ]
}
