{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/brainstorming/evidence.schema.json",
  "title": "BrainStorming Evidence Contract",
  "type": "object",
  "required": ["topic_slug", "findings"],
  "additionalProperties": true,
  "properties": {
    "topic_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "generated_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "claim": { "type": "string" },
        "summary": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW", "UNVERIFIED"]
        },
        "must_survive": { "type": "boolean" },
        "source_count": { "type": "number" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
