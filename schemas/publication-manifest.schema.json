{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainstorming.local/schemas/publication-manifest.schema.json",
  "title": "BrainStorming Publication Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "topic_slug",
    "published_files",
    "quality_score",
    "recommendation",
    "confidence_distribution",
    "must_survive_coverage"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "topic_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "published_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    },
    "confidence_distribution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "HIGH": { "type": "number", "minimum": 0 },
        "MEDIUM": { "type": "number", "minimum": 0 },
        "LOW": { "type": "number", "minimum": 0 },
        "UNVERIFIED": { "type": "number", "minimum": 0 }
      }
    },
    "must_survive_coverage": {
      "type": "string",
      "minLength": 1
    },
    "security_verdict": {
      "type": "string"
    },
    "tester_verdict": {
      "type": "string"
    },
    "challenge_verdict": {
      "type": "string"
    },
    "open_caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
