{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(topics/_tmp/**)",
      "Read(topics/*/_pipeline/**)",
      "Read(dist/public/**)",
      "Read(citation-cache/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/record-skill-invocation.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/validate-on-pipeline-write.js"
          }
        ]
      }
    ]
  }
}
